{
	"version": "2.0.0",
	"tasks": [
		{
			// Primary task for Lazarus Projects (GUI or Console with LCL)
			"label": "Build with Lazbuild (Project)",
			"type": "shell",
			// Uses the lazbuild.exe path defined in your VS Code settings
			"command": "${config:fpctoolkit.env.LAZBUILD}",
			"args": [
				"--build-mode=Debug", // Compiles using the 'Debug' profile in your .lpi
				"${fileDirname}/*.lpi" // Automatically finds the project file in the current folder
			],
			"group": {
				"kind": "build",
				"isDefault": true // Pressing Ctrl+Shift+B runs THIS task by default
			},
			"problemMatcher": []
		},
		{
			// Secondary task for quick, single-file Pascal scripts
			"label": "Build with FPC (Single File)",
			"type": "shell",
			"command": "${config:fpctoolkit.env.PP}",
			"args": [
				"-g", // Generate debug info
				"-gw2", // Use DWARF v2 debug format (best for GDB)
				"-O1", // Basic optimization
				"-FEbin", // Places the final .exe in the 'bin' folder
				"-FUlib", // Places .ppu and .o files in the 'lib' folder
				"-FuC:\\lazarus\\lcl\\units\\${config:pascal.target}", // Path to Lazarus components
				"${file}" // Compiles the file currently active in your editor
			],
			"group": {
				"kind": "build",
				"isDefault": false
			},
			// This 'problemMatcher' catches errors/warnings and underlines them in your code
			"problemMatcher": {
				"owner": "external",
				"pattern": {
					"regexp": "^(.*)\\((\\d+),(\\d+)\\)\\s+(Error|Fatal|Warning|Note):\\s+(.*)$",
					"file": 1,
					"line": 2,
					"column": 3,
					"severity": 4,
					"message": 5
				}
			},
			"presentation": {
				"reveal": "always", // Shows the terminal automatically on build
				"panel": "shared" // Uses the same terminal window for every build
			}
		},
		{
			// Specialist task for forcing a debug compile on a specific .lpr
			"label": "Debug with FPC Raw",
			"type": "shell",
			"command": "${config:fpctoolkit.env.PP}",
			"args": [
				"-gw3", // Alternative debug format (DWARF v3)
				"${fileBasenameNoExtension}.lpr"
			],
			"group": {
				"kind": "build",
				"isDefault": false // Changed to false to avoid conflict with Lazbuild
			},
			"presentation": {
				"reveal": "always",
				"panel": "new", // Opens a fresh terminal window
				"focus": true // Moves cursor to the terminal automatically
			},
			"problemMatcher": []
		}
	]
}